generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── CLIENTES ────────────────────────────────────────────────

model Cliente {
  id               Int      @id @default(autoincrement())
  nombre           String
  telefono         String?
  instagram        String?
  email            String?
  fechaNacimiento  DateTime?

  zona             String?
  modoPago         String?   // efectivo, credito, permuta
  tipoBuscado      String?
  valorPresupuesto Float?
  ambientes        Int?

  origen           String?   // instagram, referido, portal, c21, etc.
  estadoBusqueda   String    @default("activo") // activo, pausado, cerrado
  tarea            String?
  proximoContacto  DateTime?
  notas            String?

  importadoDeExcel Boolean   @default(false)
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt

  busquedas            Busqueda[]
  reservas             Reserva[]
  visitasInventario    VisitaInventario[]
  interacciones        Interaccion[]
  leads                Lead[]
  propiedadesInventario PropiedadInventario[]

  @@index([estadoBusqueda])
  @@index([proximoContacto])
}

// ─── LEADS ───────────────────────────────────────────────────

model Lead {
  id               Int    @id @default(autoincrement())
  nombre           String?
  telefono         String?
  instagram        String?
  email            String?

  // INSTAGRAM_PAUTA | C21 | ZONAPROP | ARGENPROP | PROPIO | REFERIDO | MANUAL
  origen           String @default("MANUAL")
  // NUEVO | CONTACTADO | CALIFICADO | CONVERTIDO | DESCARTADO
  estado           String @default("NUEVO")

  propiedadInteres String?
  mensajeInicial   String?
  notas            String?

  scoreIA          Float?
  proyectoSugeridoId Int?
  proyectoSugerido   Proyecto? @relation("LeadSugerido", fields: [proyectoSugeridoId], references: [id])

  proyectoId       Int?
  proyecto         Proyecto? @relation("LeadAsignado", fields: [proyectoId], references: [id])

  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id])

  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  interacciones    Interaccion[]

  @@index([estado])
  @@index([origen])
}

// ─── PROYECTOS ───────────────────────────────────────────────

model Proyecto {
  id                  Int    @id @default(autoincrement())
  nombre              String
  descripcion         String?
  activo              Boolean @default(true)
  reglasClasificacion String? // JSON string con reglas para Claude
  creadoEn            DateTime @default(now())

  leadsAsignados  Lead[] @relation("LeadAsignado")
  leadsSugeridos  Lead[] @relation("LeadSugerido")
}

// ─── BÚSQUEDAS ───────────────────────────────────────────────

model Busqueda {
  id              Int    @id @default(autoincrement())
  clienteId       Int
  cliente         Cliente @relation(fields: [clienteId], references: [id])

  zonas           String  // JSON array: ["Palermo", "Villa Crespo"]
  tipoPropiedad   String?
  ambientesMin    Int?
  ambientesMax    Int?
  precioMin       Float?
  precioMax       Float?
  modoPago        String?
  cochera         Boolean?
  aptoCredito     Boolean?
  requisitosExtra String?

  // activa | pausada | cerrada
  estado          String @default("activa")

  linkCompartido  String?
  tokenPublico    String? @unique

  contextoPrevioIA String? // JSON: resumen de gustos/rechazos anteriores

  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  propiedades     PropiedadBusqueda[]

  @@index([clienteId])
}

model PropiedadBusqueda {
  id          Int    @id @default(autoincrement())
  busquedaId  Int
  busqueda    Busqueda @relation(fields: [busquedaId], references: [id], onDelete: Cascade)

  titulo      String?
  direccion   String?
  barrio      String?
  zona        String?
  precio      Float?
  expensas    Float?
  ambientes   Int?
  superficie  Float?
  cochera     Boolean?
  aptoCredito Boolean?
  descripcion String?
  fotos       String? // JSON array de URLs

  linkOriginal String
  linkMarcado  String?
  portal       String  // zonaprop | argenprop
  idExterno    String?

  // PENDIENTE | LLAMAR | CONTACTADO | VISITA_AGENDADA | VISITADO | DESCARTADO | RESERVADO
  estadoCliente    String @default("PENDIENTE")
  comentarioCliente String?

  scoreIA  Float?
  razonIA  String?
  orden    Int @default(0)

  creadoEn     DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// ─── INVENTARIO ──────────────────────────────────────────────

model PropiedadInventario {
  id              Int    @id @default(autoincrement())
  titulo          String
  direccion       String
  barrio          String?
  zona            String?
  tipo            String
  ambientes       Int?
  superficie      Float?
  cochera         Boolean @default(false)

  precioPublicado Float?
  precioNegociado Float?
  moneda          String @default("USD")

  tipoTransaccion String  // venta | alquiler
  // activa | en_negociacion | reservada | vendida | retirada
  estado          String @default("activa")

  clienteId       Int?
  cliente         Cliente? @relation(fields: [clienteId], references: [id])

  linkPortal      String?
  porcentajeComision Float?
  fotos           String? // JSON array de paths

  origen          String?

  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  visitas  VisitaInventario[]
  reservas Reserva[]
}

model VisitaInventario {
  id          Int    @id @default(autoincrement())
  propiedadId Int
  propiedad   PropiedadInventario @relation(fields: [propiedadId], references: [id])

  clienteId   Int?
  cliente     Cliente? @relation(fields: [clienteId], references: [id])

  fecha    DateTime
  feedback String?
  interes  String? // alto | medio | bajo

  creadoEn DateTime @default(now())
}

// ─── RESERVAS ────────────────────────────────────────────────

model Reserva {
  id            Int    @id @default(autoincrement())
  fechaReserva  DateTime

  clienteId     Int?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])
  nombreCliente String

  telefono      String?

  propiedadId   Int?
  propiedad     PropiedadInventario? @relation(fields: [propiedadId], references: [id])
  descripcionProp String?

  tipoTransaccion String  // compra | venta | alquiler
  zona            String?

  valorReserva    Float?
  precioNegociado Float?
  moneda          String @default("USD")

  porcentajeParteCompradora Float?
  porcentajeParteVendedora  Float?
  escribano                 Boolean @default(false)
  comisionBruta             Float?
  comisionMia               Float?

  // reservada | en_escritura | escriturada | caida
  estado        String @default("reservada")
  fechaEscritura DateTime?

  origen        String?
  comproBool    Boolean?
  vendioBool    Boolean?
  notas         String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([estado])
  @@index([fechaReserva])
}

// ─── INTERACCIONES ───────────────────────────────────────────

model Interaccion {
  id    Int    @id @default(autoincrement())
  // llamada | whatsapp | email | visita | nota | sistema
  tipo  String
  nota  String?
  fecha DateTime @default(now())

  clienteId Int?
  cliente   Cliente? @relation(fields: [clienteId], references: [id])

  leadId Int?
  lead   Lead?    @relation(fields: [leadId], references: [id])

  creadoEn DateTime @default(now())
}

// ─── PRE-LISTING ─────────────────────────────────────────────

model PreListing {
  id        Int    @id @default(autoincrement())
  direccion String?
  zona      String?
  tipo      String?
  contacto  String?
  telefono  String?

  // prospecto | contactado | captado | descartado
  estado          String @default("prospecto")
  notas           String?
  proximoContacto DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}
